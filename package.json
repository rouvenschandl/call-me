{
  "name": "call-me",
  "private": true,
  "version": "v0.2",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "vite --host",
    "dev:server": "bun --watch server.ts",
    "build": "vue-tsc -b && vite build",
    "build:server": "bunx tsc server.ts --outDir dist-server --module ESNext --moduleResolution bundler --target ES2020 --esModuleInterop",
    "start": "bun dist-server/server.js",
    "docker:build": "docker build -t call-me .",
    "docker:start": "docker run --rm --env-file .env -p 3000:3000 call-me",
    "lint": "bunx --bun @biomejs/biome lint",
    "lint:fix": "bunx --bun @biomejs/biome lint --write",
    "format": "bunx --bun @biomejs/biome format --write",
    "check": "bunx --bun @biomejs/biome check",
    "check:fix": "bunx --bun @biomejs/biome check --write",
    "check:types": "next typegen && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.24",
    "socket.io-client": "^4.8.1",
    "express": "^4.21.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.10.1",
    "@types/express": "^4.17.21",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4"
  }
}
